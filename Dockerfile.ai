FROM python:3.11-slim

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements-ai-api.txt .
RUN pip install --no-cache-dir -r requirements-ai-api.txt

COPY ai_api.py ai_utils.py ai_rag.py ai_parsers.py ai_sast.py ai_dast.py ./
COPY static ./static

ENV RAG_MODE=builtin
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

HEALTHCHECK CMD curl --fail http://localhost:8000/health || exit 1

CMD ["uvicorn", "ai_api:app", "--host", "0.0.0.0", "--port", "8000"]
